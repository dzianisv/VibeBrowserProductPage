INDEXNOW_KEY=""
INDEXNOW_HOSTS="vibebrowser.app,enterprise.vibebrowser.app"
INDEXNOW_URL_PATHS="/,/teams,/mcp,/v2,/tee,/compare,/privacy,/terms"
BREVO_API_KEY=""
BREVO_LIST_ID=""
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=""
NEXT_PUBLIC_BING_SITE_VERIFICATION=""
NEXT_PUBLIC_POSTHOG_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="/ingest"
NEXT_PUBLIC_POSTHOG_UI_HOST="https://us.posthog.com"

# Optional Honeycomb/OpenTelemetry tracing
# Example:
# OTEL_EXPORTER_OTLP_ENDPOINT="https://api.honeycomb.io"
# OTEL_EXPORTER_OTLP_HEADERS="x-honeycomb-team=YOUR_API_KEY,x-honeycomb-dataset=YOUR_DATASET"
OTEL_SERVICE_NAME="vibebrowser-product-page"
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""

# Vercel deployment — required for Git LFS video/media files to be pulled during build
# Set this in Vercel project settings (not in .env.local)
GIT_LFS_ENABLED=1

# opencode.agentlabs.cc signup (POST /api/beta-signup) — see
# docs/opencode-beta-signup.md
# Persistence + founder notification (required):
SUPABASE_PROJECT_URL=""
SUPABASE_API_KEY=""
RESEND_API_KEY=""
BETA_NOTIFY_EMAIL="vibeteaichnologies@gmail.com"
# Optional: exact Play Console closed-testing "Testers" tab URL for the
# one-click link in the founder notification email (see docs).
PLAY_CONSOLE_TESTERS_URL=""

# Brevo mailing lists. Two separate lists, selected per-request via the
# `list` field in the POST body ("beta" default | "news"). Create both
# lists in Brevo and set their numeric ids here — never hardcode ids in
# code. NOTE: Brevo has IP allowlisting that can silently 401 all API
# calls from Vercel — disable it (or allowlist Vercel's egress IPs) or
# nothing will sync. See docs/opencode-beta-signup.md.
BREVO_API_KEY=""
BREVO_OPENCODE_NEWS_LIST_ID=""
BREVO_OPENCODE_BETA_LIST_ID=""

# Gated Google Play auto-enroll via Google Group (optional — skipped
# silently until both are set; see docs/opencode-beta-signup.md for the
# one-time Cloud Identity + Google Group setup):
GOOGLE_GROUPS_SA_JSON=""
PLAY_BETA_GROUP_EMAIL="beta-testers@agentlabs.cc"
GOOGLE_GROUPS_IMPERSONATE_EMAIL=""
